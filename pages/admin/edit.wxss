/* pages/admin/edit.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.block {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.block-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.req {
  color: #ff4d4f;
}

/* 图片选择 */
.img-picker {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: var(--color-primary-light);
  border: 2rpx dashed var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.img-preview {
  width: 100%;
  height: 100%;
}

.img-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.img-plus {
  font-size: 56rpx;
  color: var(--color-primary);
  line-height: 1;
}

.img-tip {
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-top: 6rpx;
}

.img-uploaded {
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 12rpx;
}

/* 输入框 */
.input {
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 选择器 */
.picker {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 28rpx;
}

/* 食材/调料行 */
.line {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.line-name {
  flex: 1;
  margin-right: 12rpx;
}

.line-amount {
  width: 200rpx;
  margin-right: 12rpx;
}

.line-del {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  color: #ff4d4f;
  font-size: 28rpx;
  flex-shrink: 0;
}

.add-line {
  display: inline-block;
  color: var(--color-primary);
  font-size: 26rpx;
  padding: 8rpx 0;
}

/* 步骤行 */
.step-line {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.step-idx {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background-color: var(--color-primary);
  color: #ffffff;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 14rpx;
  margin-right: 12rpx;
}

.step-text {
  flex: 1;
  min-height: 72rpx;
  padding: 16rpx 20rpx;
  margin-right: 12rpx;
}

/* 保存按钮 */
.save-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 32rpx;
  text-align: center;
  padding: 26rpx 0;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.save-btn.saving {
  opacity: 0.6;
}

/* 非主人拦截 */
.deny {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.deny-icon {
  font-size: 100rpx;
}

.deny-text {
  font-size: 28rpx;
  color: var(--color-text-sub);
  margin-top: 24rpx;
}
