/* pages/detail/detail.wxss */
.page {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ===== 顶部图片 ===== */
.dish-cover {
  width: 100%;
  height: 420rpx;
  background-color: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  font-size: 160rpx;
}

/* ===== 菜品名称 + 加入按钮 ===== */
.dish-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 8rpx;
}

.dish-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text);
}

.add-btn {
  flex-shrink: 0;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  border-radius: 999rpx;
  background-color: var(--color-primary);
  color: #ffffff;
}

.add-btn.added {
  background-color: #f0f0f0;
  color: var(--color-text-sub);
}

/* ===== 通用 section ===== */
.section {
  margin: 24rpx 32rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 14rpx;
}

.dot-green { background-color: #52c41a; }
.dot-orange { background-color: #ff7a45; }
.dot-blue { background-color: #1890ff; }

/* ===== 食材 / 调味料 列表 ===== */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 28rpx;
}

.list-item:last-child {
  border-bottom: none;
}

.item-name {
  color: var(--color-text);
}

.item-amount {
  color: var(--color-text-sub);
}

.empty-inline {
  color: var(--color-text-sub);
  font-size: 26rpx;
  padding: 12rpx 0;
}

/* ===== 制作过程 ===== */
.step {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.step-num {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background-color: var(--color-primary);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
  margin-top: 2rpx;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.6;
}

/* ===== 底部 ===== */
.footer-tip {
  text-align: center;
  color: var(--color-text-sub);
  font-size: 24rpx;
  margin-top: 48rpx;
}
