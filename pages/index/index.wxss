/* pages/index/index.wxss */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ===== 顶部标题区 ===== */
.header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--color-border);
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 24rpx;
  flex-shrink: 0;
  background-color: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 48rpx;
}

.header-text {
  flex: 1;
  min-width: 0;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
}

.subtitle {
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-top: 6rpx;
}

/* 顶部「我的订单」入口 */
.order-entry {
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding: 12rpx 22rpx;
  background-color: var(--color-primary-light);
  border-radius: 999rpx;
}

.order-entry-icon {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.order-entry-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

.order-entry-badge {
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  margin-left: 10rpx;
  padding: 0 8rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

/* ===== 主体：左分类 + 右列表 ===== */
.content {
  flex: 1;
  display: flex;
  min-height: 0;
  padding-bottom: 120rpx; /* 给底部浮动按钮留位置 */
  box-sizing: border-box;
}

/* 左侧分类栏 */
.category-bar {
  width: 180rpx;
  height: 100%;
  background-color: #f7f7f7;
  flex-shrink: 0;
}

.category-item {
  position: relative;
  padding: 32rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-sub);
}

.category-item.active {
  background-color: #ffffff;
  color: var(--color-primary);
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background-color: var(--color-primary);
  border-radius: 0 6rpx 6rpx 0;
}

/* 右侧菜品列表 */
.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.dish-card {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.dish-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-img-inner {
  width: 100%;
  height: 100%;
}

.dish-img-placeholder {
  font-size: 56rpx;
}

.dish-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

/* 加入菜单按钮 */
.add-btn {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
  background-color: var(--color-primary);
  color: #ffffff;
}

.add-btn.added {
  background-color: #f0f0f0;
  color: var(--color-text-sub);
}

.empty {
  text-align: center;
  color: var(--color-text-sub);
  padding: 80rpx 0;
  font-size: 26rpx;
}

/* ===== 底部浮动按钮：我的菜单 ===== */
.cart-btn {
  position: fixed;
  right: 32rpx;
  bottom: 48rpx;
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 0 36rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 122, 69, 0.45);
  z-index: 100;
}

/* 空菜单时弱化样式，避免误以为是装饰 */
.cart-btn-empty {
  background-color: #ffffff;
  color: var(--color-primary);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.cart-icon {
  font-size: 40rpx;
  margin-right: 14rpx;
}

.cart-info {
  display: flex;
  flex-direction: column;
}

.cart-text {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
}

.cart-sub {
  font-size: 20rpx;
  opacity: 0.85;
  margin-top: 2rpx;
}
