/* pages/login/login.wxss */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  background-color: var(--color-bg);
}

.logo {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text);
}

.subtitle {
  font-size: 26rpx;
  color: var(--color-text-sub);
  margin-top: 12rpx;
}

.form {
  width: 100%;
  margin-top: 96rpx;
  padding: 0 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 头像预览 */
.avatar-preview {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 32rpx;
  background-color: var(--color-primary-light);
}

.avatar-preview-img {
  width: 100%;
  height: 100%;
}

/* 昵称输入 */
.nickname-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

/* 微信一键登录按钮 */
.wx-login-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.wx-login-btn::after { border: none; }

.wx-login-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 进入按钮 */
.enter-btn {
  width: 100%;
  text-align: center;
  padding: 26rpx 0;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.enter-btn.entering {
  opacity: 0.6;
}

/* 相册次要入口 */
.album-entry {
  margin-top: 32rpx;
  font-size: 24rpx;
  color: var(--color-text-sub);
  padding: 12rpx 0;
}
