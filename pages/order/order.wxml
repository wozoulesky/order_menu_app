<!--pages/order/order.wxml-->
<view class="page">

  <!-- 身份栏：登录前置后所有人已登录，只显示已登录态 -->
  <view class="profile-bar">
    <view class="profile-avatar">
      <image wx:if="{{userInfo.avatarUrl}}" class="profile-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="profile-avatar-placeholder">👤</view>
    </view>
    <view class="profile-info">
      <view class="profile-name">{{userInfo.nickName}}</view>
      <view class="profile-role">{{isMaster ? '👑 主人（可看全部订单）' : '点餐人'}}</view>
    </view>
    <!-- 主人专属：添加菜品入口 -->
    <view wx:if="{{isMaster}}" class="add-dish-btn" bindtap="onAddDishTap">➕ 加菜</view>
    <view class="logout-btn" bindtap="onLogout">退出</view>
  </view>

  <!-- ===== 提交订单区 ===== -->
  <view class="card">
    <view class="card-title">本次菜单</view>

    <view wx:if="{{menu.length === 0}}" class="empty">还没选菜，去首页加几道吧～</view>

    <view wx:else>
      <view class="menu-item" wx:for="{{menu}}" wx:key="id">
        <text class="menu-name">{{item.name}}</text>
        <text class="menu-remove" data-id="{{item.id}}" bindtap="onRemoveDish">移除</text>
      </view>

      <view class="submit-btn" bindtap="onSubmit">提交订单</view>
    </view>
  </view>

  <!-- ===== 历史订单区 ===== -->
  <view class="card">
    <view class="card-title">{{isMaster ? '所有订单（主人视角）' : '我的历史订单'}}</view>

    <view wx:if="{{loadingOrders}}" class="empty">加载中…</view>

    <view wx:elif="{{orders.length === 0}}" class="empty">还没有订单</view>

    <view wx:else>
      <view class="order-item" wx:for="{{orders}}" wx:key="_id">
        <view class="order-head">
          <text class="order-who">{{item.nickname || '匿名朋友'}}</text>
          <text class="order-time">{{item.timeText}}</text>
        </view>
        <view class="order-dishes">
          <text class="order-dish" wx:for="{{item.dishes}}" wx:for-item="dish" wx:key="id">
            {{dish.name}}
          </text>
        </view>
      </view>
    </view>
  </view>

</view>
