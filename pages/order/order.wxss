/* pages/order/order.wxss */
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 身份栏 ===== */
.profile-bar {
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.profile-bar-done {
  flex-direction: row;
  align-items: center;
}

.profile-tip {
  font-size: 26rpx;
  color: var(--color-text-sub);
  margin-bottom: 20rpx;
}

.profile-tip-sub {
  font-size: 22rpx;
  color: #bbbbbb;
}

.profile-form {
  display: flex;
  align-items: center;
}

.avatar-pick {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx dashed var(--color-primary);
  box-sizing: border-box;
}

.avatar-pick-img {
  width: 100%;
  height: 100%;
}

.avatar-pick-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.avatar-pick-plus {
  font-size: 36rpx;
  color: var(--color-primary);
  line-height: 1;
}

.avatar-pick-label {
  font-size: 20rpx;
  color: var(--color-text-sub);
  margin-top: 2rpx;
}

.nickname-input {
  flex: 1;
  margin: 0 20rpx;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.save-profile-btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* 已登录态 */
.profile-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: var(--color-primary-light);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar-img {
  width: 100%;
  height: 100%;
}

.profile-avatar-placeholder {
  font-size: 40rpx;
}

.profile-info {
  flex: 1;
  margin-left: 20rpx;
}

.profile-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.profile-role {
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-top: 4rpx;
}

.logout-btn {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--color-text-sub);
}

/* 主人：添加菜品按钮 */
.add-dish-btn {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

/* ===== 通用卡片 ===== */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.empty {
  text-align: center;
  color: var(--color-text-sub);
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* ===== 本次菜单 ===== */
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.menu-item:last-of-type {
  border-bottom: none;
}

.menu-name {
  font-size: 28rpx;
  color: var(--color-text);
}

.menu-remove {
  font-size: 24rpx;
  color: #ff4d4f;
  padding: 6rpx 16rpx;
}

.submit-btn {
  margin-top: 24rpx;
  text-align: center;
  padding: 24rpx 0;
  background-color: var(--color-primary);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.submit-btn:active {
  opacity: 0.85;
}

/* ===== 历史订单 ===== */
.order-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.order-item:last-child {
  border-bottom: none;
}

.order-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-who {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}

.order-time {
  font-size: 24rpx;
  color: var(--color-text-sub);
}

.order-dishes {
  display: flex;
  flex-wrap: wrap;
}

.order-dish {
  font-size: 24rpx;
  color: var(--color-primary);
  background-color: var(--color-primary-light);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}
